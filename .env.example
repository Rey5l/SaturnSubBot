# Токен бота от @BotFather
BOT_TOKEN=8450626723:AAHkbONr-iGmAQgtcAMIBxZXkkI0_QM82AM

# Имя бота для реферальной ссылки (без @), например SaturnEarnBot
BOT_USERNAME=SaturnSubBot

# API-токен Crypto Pay (получить в @CryptoBot → Crypto Pay → Create App)
CRYPTO_PAY_API_TOKEN=

# Сеть: MAIN_NET или TEST_NET (для тестов)
CRYPTO_PAY_NETWORK=MAIN_NET

# Валюта вывода по умолчанию: USDT, TON, BTC, ETH и т.д.
WITHDRAW_ASSET=USDT

# Минимальная сумма вывода (в выбранной валюте)
MIN_WITHDRAW_AMOUNT=1

# Реферальный бонус: доля от вывода приглашённого (0.30 = 30%)
REFERRAL_BONUS_RATE=0.30

# ID администраторов через запятую (могут зачислять баланс)
ADMIN_IDS=123456789

# Ссылки на ботов заданий (@tgrassbot и @FlyerServiceBot)
TGRASSA_BOT_LINK=https://t.me/tgrassbot
FLYER_BOT_LINK=https://t.me/FlyerServiceBot

# Токены/API-ключи платформ заданий
TGRASSA_API_KEY=
FLYER_API_KEY=

# Tgrassa API (если есть: базовый URL и проверка SSL)
TGRASSA_API_BASE=https://tgrass.space
# false — отключить проверку SSL (если ошибка сертификата на macOS/Windows)
TGRASSA_API_SSL_VERIFY=false

# Webhook Tgrass (события при отписках). Порт 0 = отключить приём.
#
# Как задать:
#   Порт — любой свободный порт (например 8080). Путь — по умолчанию /webhook/tgrass.
#
# --- Сервер с выделенным (статическим) IP ---
# 1. На сервере в .env: TGRASSA_WEBHOOK_PORT=8080 (и TGRASSA_WEBHOOK_PATH=/webhook/tgrass).
# 2. Откройте порт 8080 в файрволе сервера (ufw, firewalld, iptables или панель хостинга).
# 3. В кабинете Tgrass укажите URL:  http://ВАШ_ВЫДЕЛЕННЫЙ_IP:8080/webhook/tgrass
#    Пример: http://185.12.34.56:8080/webhook/tgrass
# 4. Если Tgrass принимает только HTTPS: привяжите домен к этому IP (A-запись), поставьте nginx + Let's Encrypt (certbot), проксируйте https на localhost:8080, в Tgrass укажите https://ваш-домен.ru/webhook/tgrass
#
# Есть домен: в Tgrass укажите https://ВАШ_ДОМЕН:8080/webhook/tgrass (или через nginx без :8080).
#
# Нет домена и нет выделенного IP — туннель (ngrok или Cloudflare, см. ниже).
#
# --- Cloudflare (cloudflared), бесплатно ---
# 1. Установите cloudflared:
#    macOS (Homebrew):  brew install cloudflared
#    Windows: скачайте с https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/install-and-setup/installation/
#    Linux: см. https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/install-and-setup/installation/
# 2. В .env включите: TGRASSA_WEBHOOK_PORT=8080
# 3. Запустите бота (он слушает порт 8080).
# 4. В другом терминале выполните:
#      cloudflared tunnel --url http://127.0.0.1:8080
# 5. В выводе найдите строку с URL вида: https://xxxx-xx-xx-xx-xx.xxxxx.trycloudflare.com
# 6. В кабинете Tgrass укажите webhook:  https://ЭТОТ_URL/webhook/tgrass
#    (подставьте ваш URL из шага 5, путь /webhook/tgrass)
# При каждом новом запуске cloudflared URL может меняться — тогда обновите URL в Tgrass.
#
# Сервер на Windows, тестируете на Mac: один URL не может «прийти на Mac, а обработаться на Windows».
# Варианты: (1) Тест — бот+туннель на Mac, в Tgrass URL с Mac. Прод — бот+туннель на Windows, в Tgrass меняете URL.
# (2) Реле: туннель на Mac + прокси на Mac, который пересылает POST на http://IP_WINDOWS:8080/webhook/tgrass; бот на Windows. Тогда в Tgrass один раз указываете URL с Mac.
#
# TGRASSA_WEBHOOK_PORT=8080
# TGRASSA_WEBHOOK_PATH=/webhook/tgrass

# Проверка SSL при запросах к Flyer API (false — если ошибка сертификата на macOS)
FLYER_API_SSL_VERIFY=true

# Доля награды задания, которую получает пользователь (остальное — маржа бота). 0.0–1.0
# Например 0.70: с задания на 1$ пользователь получает 70¢, бот оставляет 30¢
TGRASSA_PAYOUT_RATE=0.70
# Фиксированная выплата за одно Fly-задание в долларах
FLYER_PAYOUT_PER_TASK=0.010
